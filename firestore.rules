rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reads on collections used by the app UI
    match /Agents/{agentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Daily schedules and break slots structure used by the app
    match /dailySchedules/{date} {
      allow read: if true;
      allow write: if request.auth != null;
      match /breakSlots/{slotId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // App state for banner
    match /appState/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
